generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum UserRole {
  SUPER_ADMIN
  HR_ADMIN
  MANAGER
  EMPLOYEE
}

enum AccountStatus {
  ACTIVE
  INACTIVE
  LOCKED
}

enum EmploymentType {
  FULL_TIME
  PART_TIME
  CONTRACT
  INTERN
}

enum AttendanceStatus {
  PRESENT
  ABSENT
  HALF_DAY
  LEAVE
  HOLIDAY
  WEEKEND
}

enum LeaveRequestStatus {
  PENDING
  APPROVED
  REJECTED
  CANCELLED
}

enum AnnouncementAudienceType {
  ALL
  DEPARTMENT
  ROLE
}

enum DocumentCategory {
  OFFER_LETTER
  ID_PROOF
  PAYSLIP
  POLICY
  EMPLOYEE_UPLOAD
}

model User {
  id             String        @id @default(cuid())
  email          String        @unique
  passwordHash   String
  role           UserRole
  status         AccountStatus @default(ACTIVE)
  lastLoginAt    DateTime?
  createdAt      DateTime      @default(now())
  updatedAt      DateTime      @updatedAt
  deletedAt      DateTime?
  employee       Employee?
  announcements  Announcement[] @relation("CreatedAnnouncements")
  auditLogs      AuditLog[]
}

model Department {
  id           String         @id @default(cuid())
  name         String         @unique
  code         String         @unique
  createdAt    DateTime       @default(now())
  updatedAt    DateTime       @updatedAt
  deletedAt    DateTime?
  employees    Employee[]
  announcements Announcement[]
}

model Designation {
  id          String      @id @default(cuid())
  title       String      @unique
  level       String?
  createdAt   DateTime    @default(now())
  updatedAt   DateTime    @updatedAt
  deletedAt   DateTime?
  employees   Employee[]
}

model Employee {
  id                   String          @id @default(cuid())
  employeeCode         String          @unique
  firstName            String
  lastName             String
  phone                String?
  dateOfBirth          DateTime?
  gender               String?
  address              String?
  emergencyContactName String?
  emergencyContactPhone String?
  joiningDate          DateTime
  employmentType       EmploymentType
  workLocation         String?
  bankAccountNumber    String?
  bankIfsc             String?
  panNumber            String?
  aadhaarNumber        String?
  profilePhotoUrl      String?
  createdAt            DateTime        @default(now())
  updatedAt            DateTime        @updatedAt
  deletedAt            DateTime?
  userId               String          @unique
  departmentId         String?
  designationId        String?
  managerId            String?
  user                 User            @relation(fields: [userId], references: [id])
  department           Department?     @relation(fields: [departmentId], references: [id])
  designation          Designation?    @relation(fields: [designationId], references: [id])
  manager              Employee?       @relation("ReportingManager", fields: [managerId], references: [id])
  reportees            Employee[]      @relation("ReportingManager")
  attendanceRecords    AttendanceRecord[]
  leaveBalances        LeaveBalance[]
  leaveRequests        LeaveRequest[]  @relation("RequestEmployee")
  approvals            LeaveRequest[]  @relation("ApproverEmployee")
  documents            EmployeeDocument[]
  payrollInputs        PayrollInput[]

  @@index([departmentId])
  @@index([managerId])
}

model AttendanceRecord {
  id              String           @id @default(cuid())
  employeeId      String
  date            DateTime
  checkInAt       DateTime?
  checkOutAt      DateTime?
  status          AttendanceStatus
  regularizationNote String?
  approvedById    String?
  createdAt       DateTime         @default(now())
  updatedAt       DateTime         @updatedAt
  employee        Employee         @relation(fields: [employeeId], references: [id])

  @@unique([employeeId, date])
  @@index([date])
}

model LeaveType {
  id             String          @id @default(cuid())
  code           String          @unique
  name           String
  annualQuota    Float
  isPaid         Boolean         @default(true)
  requiresProof  Boolean         @default(false)
  createdAt      DateTime        @default(now())
  updatedAt      DateTime        @updatedAt
  balances       LeaveBalance[]
  requests       LeaveRequest[]
}

model LeaveBalance {
  id            String    @id @default(cuid())
  employeeId    String
  leaveTypeId   String
  year          Int
  allocated     Float
  used          Float     @default(0)
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt
  employee      Employee  @relation(fields: [employeeId], references: [id])
  leaveType     LeaveType @relation(fields: [leaveTypeId], references: [id])

  @@unique([employeeId, leaveTypeId, year])
}

model LeaveRequest {
  id             String             @id @default(cuid())
  employeeId     String
  leaveTypeId    String
  approverId     String?
  startDate      DateTime
  endDate        DateTime
  days           Float
  reason         String?
  status         LeaveRequestStatus @default(PENDING)
  appliedAt      DateTime           @default(now())
  decidedAt      DateTime?
  createdAt      DateTime           @default(now())
  updatedAt      DateTime           @updatedAt
  employee       Employee           @relation("RequestEmployee", fields: [employeeId], references: [id])
  leaveType      LeaveType          @relation(fields: [leaveTypeId], references: [id])
  approver       Employee?          @relation("ApproverEmployee", fields: [approverId], references: [id])

  @@index([employeeId, status])
}

model Holiday {
  id            String    @id @default(cuid())
  name          String
  date          DateTime
  location      String?
  isOptional    Boolean   @default(false)
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt

  @@unique([date, name])
}

model Announcement {
  id             String                   @id @default(cuid())
  title          String
  body           String
  audienceType   AnnouncementAudienceType @default(ALL)
  targetRole     UserRole?
  departmentId   String?
  expiresAt      DateTime?
  createdAt      DateTime                 @default(now())
  updatedAt      DateTime                 @updatedAt
  createdById    String
  createdBy      User                     @relation("CreatedAnnouncements", fields: [createdById], references: [id])
  department     Department?              @relation(fields: [departmentId], references: [id])

  @@index([audienceType, expiresAt])
}

model EmployeeDocument {
  id            String           @id @default(cuid())
  employeeId    String
  category      DocumentCategory
  fileName      String
  fileUrl       String
  uploadedById  String
  createdAt     DateTime         @default(now())
  updatedAt     DateTime         @updatedAt
  employee      Employee         @relation(fields: [employeeId], references: [id])

  @@index([employeeId, category])
}

model PayrollInput {
  id               String    @id @default(cuid())
  employeeId       String
  month            Int
  year             Int
  baseSalary       Decimal?  @db.Decimal(12, 2)
  reimbursements   Decimal?  @db.Decimal(12, 2)
  deductions       Decimal?  @db.Decimal(12, 2)
  variablePay      Decimal?  @db.Decimal(12, 2)
  notes            String?
  createdAt        DateTime  @default(now())
  updatedAt        DateTime  @updatedAt
  employee         Employee  @relation(fields: [employeeId], references: [id])

  @@unique([employeeId, month, year])
}

model AuditLog {
  id           String   @id @default(cuid())
  actorUserId  String
  action       String
  entityType   String
  entityId     String
  metadata     Json?
  createdAt    DateTime @default(now())
  actorUser    User     @relation(fields: [actorUserId], references: [id])

  @@index([entityType, entityId])
}

model WorkLocation {
  id        String    @id @default(cuid())
  name      String    @unique
  code      String    @unique
  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt
  deletedAt DateTime?
}
